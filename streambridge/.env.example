# ─── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streambridge
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-32-byte-random-string-please
TOKEN_ENCRYPTION_KEY=change-me-32-byte-hex-or-random-string

# ─── Spotify (https://developer.spotify.com/dashboard) ─────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4000/auth/spotify/callback

# ─── Apple Music (https://developer.apple.com/account/resources/authkeys/list) ─
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── Amazon Music / Login with Amazon (https://developer.amazon.com/lwa/) ──────
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REDIRECT_URI=http://localhost:4000/auth/amazon-music/callback

# ─── Tidal (https://developer.tidal.com) ───────────────────────────────────────
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://localhost:4000/auth/tidal/callback

# ─── YouTube Music / Google (https://console.cloud.google.com/apis/credentials) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/youtube-music/callback

# ─── Deezer (https://developers.deezer.com/myapps) ─────────────────────────────
DEEZER_APP_ID=
DEEZER_APP_SECRET=
DEEZER_REDIRECT_URI=http://localhost:4000/auth/deezer/callback

# ─── Pandora Partner API (request access via partners.pandora.com) ─────────────
PANDORA_PARTNER_USERNAME=
PANDORA_PARTNER_PASSWORD=
PANDORA_DEVICE_MODEL=android-generic

# ─── Mobile (Expo) ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000
