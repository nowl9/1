# Deribit (public market data — no auth needed for read-only)
DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2
DERIBIT_TESTNET_WS_URL=wss://test.deribit.com/ws/api/v2
DERIBIT_USE_TESTNET=false

# Polymarket CLOB
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CHAIN_ID=137

# Kalshi
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
KALSHI_USE_DEMO=true
KALSHI_DEMO_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_PROD_URL=https://api.elections.kalshi.com/trade-api/v2

# Strategy parameters
MIN_EDGE=0.03
MIN_DAYS_TO_EXPIRY=1
MAX_DAYS_TO_EXPIRY=90
STRIKE_DELTA=500

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Risk limits (PAPER caps; execution/risk_limits.py -- OS env wins over .env)
# RISK_MAX_POSITION_PER_MARKET=500
# RISK_MAX_GLOBAL_EXPOSURE=5000
# RISK_MAX_DAILY_LOSS=500
